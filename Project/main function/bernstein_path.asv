% ============== Change log ===============================================
% XX/02 - Created the function 1D
% 15/04 - Bernstein parametrization applied to 2D (x and y coords)
% 25/04 - Changed reference system for coords to normal and tangential,
%         see Cluade informed suggestions:
%         https://claude.ai/share/8e0523b2-b95a-4cbc-a5d9-7cfd32f24655
% =========================================================================

function P = bernstein_path(alpha_n, Par)
    % alpha: [n x 1] vector of optimization variables (deviations)
    n = length(alpha_n) /2;
    eta = alpha_n(1:n);
    tau = alpha_n(n+1:end);
    A = Par.A;      
    B = Par.B;     
    dc = Par.dc;       
    t = (0:dc:1)';   
    
    % Geometry setup
    dir_vec = B - A;
    L       = norm(dir_vec);
    t_hat   = dir_vec / L;                       % unit tangent
    n_hat   = [-t_hat(2); t_hat(1)];             % unit normal (left-hand)
    
    % --- Generalized Bernstein Basis ---
    % Degree of the polynomial k = n + 1 (since alpha1...alphan are internal nodes)
    % The start (t=0) and end (t=1) points are fixed to A and B.
    
    k = n + 1;   % Bernstein degree
    dev_n = zeros(size(t)); %deviation = zeros(size(t)); % 1D
    dev_t = zeros(size(t));
    
    for i = 1:n
        % Bernstein Basis function B_{i,k}(t) = comb(k,i) * t^i * (1-t)^(k-i)
        % We use i=1 to n to exclude the fixed endpoints at i=0 and i=k+1
        basis   = nchoosek(k, i) .* (t.^i) .* ((1-t).^(k-i));
        dev_n   = dev_n + eta(i) * basis;
        dev_t   = dev_t + tau(i) * basis;
    end
    
    baseline = A' + t* dir_vec';
    %P = baseline + deviation * n_vec'; % 1D
    P = baseline + dev_n * n_hat' + dev_t * t_hat';
end



